# Copy this file to .env and fill your demo credentials
# Never share this file publicly.

QUOTEX_EMAIL=your_email@example.com
QUOTEX_PASSWORD=your_password

# Optional: if you already have demo SSID, set it and bot will skip login helper
QUOTEX_DEMO_SSID=

# Bot setup
BOT_ASSET=EURUSD_otc
BOT_TIMEFRAME=60
BOT_MAX_CANDLES=120
BOT_OUTPUT_DIR=data
